{
  "name": "stillpoint",
  "private": true,
  "version": "1.1.0",
  "description": "Stillpoint — ambient sound regulator powered by sonic-core",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "verify": "npm test && npm run build --workspace=packages/ui"
  },
  "engines": {
    "node": ">=20"
  }
}
