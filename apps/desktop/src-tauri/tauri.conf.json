{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemas/main/tauri-2/tauri.conf.json",
  "productName": "Stillpoint",
  "version": "0.1.0",
  "identifier": "com.mcptoolshop.stillpoint",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../../packages/ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stillpoint",
        "width": 700,
        "height": 500,
        "minWidth": 500,
        "minHeight": 400,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:3456 http://localhost:5173; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
